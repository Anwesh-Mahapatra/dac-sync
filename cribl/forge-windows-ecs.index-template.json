{
  "index_patterns": ["forge-windows-ecs*"],
  "priority": 500,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "dynamic_templates": [
        {
          "winlog_event_data_longstrings": {
            "path_match": [
              "winlog.event_data.CommandLine",
              "winlog.event_data.ParentCommandLine",
              "winlog.event_data.Image",
              "winlog.event_data.ParentImage",
              "winlog.event_data.OriginalFileName",
              "winlog.event_data.TargetFilename",
              "winlog.event_data.CurrentDirectory",
              "winlog.event_data.Details",
              "winlog.event_data.TargetObject",
              "winlog.event_data.ImageLoaded",
              "winlog.event_data.SourceImage",
              "winlog.event_data.TargetImage",
              "winlog.event_data.CallTrace"
            ],
            "match_mapping_type": "string",
            "mapping": {
              "type": "wildcard",
              "fields": {
                "text": { "type": "match_only_text" }
              }
            }
          }
        },
        {
          "winlog_event_data_strings": {
            "path_match": "winlog.event_data.*",
            "match_mapping_type": "string",
            "mapping": {
              "type": "keyword",
              "ignore_above": 1024,
              "fields": {
                "text": { "type": "match_only_text" }
              }
            }
          }
        }
      ],
      "properties": {
        "@timestamp": { "type": "date" },

        "ecs": {
          "properties": {
            "version": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "event": {
          "properties": {
            "code": { "type": "keyword", "ignore_above": 1024 },
            "provider": { "type": "keyword", "ignore_above": 1024 },
            "kind": { "type": "keyword", "ignore_above": 1024 },
            "category": { "type": "keyword", "ignore_above": 1024 },
            "type": { "type": "keyword", "ignore_above": 1024 },
            "outcome": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "host": {
          "properties": {
            "name": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "process": {
          "properties": {
            "pid": { "type": "long" },
            "entity_id": { "type": "keyword", "ignore_above": 1024 },
            "name": {
              "type": "keyword",
              "ignore_above": 1024,
              "fields": { "text": { "type": "match_only_text" } }
            },
            "executable": {
              "type": "keyword",
              "ignore_above": 1024,
              "fields": { "text": { "type": "match_only_text" } }
            },
            "command_line": {
              "type": "wildcard",
              "fields": { "text": { "type": "match_only_text" } }
            },
            "working_directory": {
              "type": "keyword",
              "ignore_above": 1024,
              "fields": { "text": { "type": "match_only_text" } }
            },
            "args": { "type": "keyword", "ignore_above": 1024 },
            "hash": {
              "properties": {
                "md5": { "type": "keyword", "ignore_above": 1024 },
                "sha1": { "type": "keyword", "ignore_above": 1024 },
                "sha256": { "type": "keyword", "ignore_above": 1024 }
              }
            },
            "pe": {
              "properties": {
                "original_file_name": { "type": "keyword", "ignore_above": 1024 },
                "product": { "type": "keyword", "ignore_above": 1024 },
                "company": { "type": "keyword", "ignore_above": 1024 },
                "file_version": { "type": "keyword", "ignore_above": 1024 },
                "description": { "type": "keyword", "ignore_above": 1024 },
                "imphash": { "type": "keyword", "ignore_above": 1024 }
              }
            },
            "parent": {
              "properties": {
                "pid": { "type": "long" },
                "entity_id": { "type": "keyword", "ignore_above": 1024 },
                "name": {
                  "type": "keyword",
                  "ignore_above": 1024,
                  "fields": { "text": { "type": "match_only_text" } }
                },
                "executable": {
                  "type": "keyword",
                  "ignore_above": 1024,
                  "fields": { "text": { "type": "match_only_text" } }
                },
                "command_line": {
                  "type": "wildcard",
                  "fields": { "text": { "type": "match_only_text" } }
                },
                "args": { "type": "keyword", "ignore_above": 1024 }
              }
            }
          }
        },

        "file": {
          "properties": {
            "path": {
              "type": "keyword",
              "ignore_above": 1024,
              "fields": { "text": { "type": "match_only_text" } }
            },
            "name": { "type": "keyword", "ignore_above": 1024 },
            "directory": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "user": {
          "properties": {
            "name": { "type": "keyword", "ignore_above": 1024 },
            "domain": { "type": "keyword", "ignore_above": 1024 },
            "id": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "source": {
          "properties": {
            "ip": { "type": "ip" },
            "port": { "type": "long" }
          }
        },

        "destination": {
          "properties": {
            "ip": { "type": "ip" },
            "port": { "type": "long" },
            "domain": { "type": "keyword", "ignore_above": 1024 },
            "address": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "network": {
          "properties": {
            "transport": { "type": "keyword", "ignore_above": 1024 },
            "protocol": { "type": "keyword", "ignore_above": 1024 }
          }
        },

        "winlog": {
          "properties": {
            "event_id": { "type": "long" },
            "channel": { "type": "keyword", "ignore_above": 1024 },
            "computer_name": { "type": "keyword", "ignore_above": 1024 },
            "record_id": { "type": "keyword", "ignore_above": 1024 },
            "logon": {
              "properties": {
                "type": { "type": "keyword", "ignore_above": 1024 }
              }
            }
          }
        },

        "log": {
          "properties": {
            "file": {
              "properties": {
                "path": { "type": "keyword", "ignore_above": 1024 }
              }
            }
          }
        }
      }
    }
  }
}
