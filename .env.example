# Copy to .env and fill in real values. .env is gitignored -- never commit it.
#
# ELASTIC_PASSWORD / KIBANA_SYSTEM_PASSWORD: any string, rotate freely.
#
# KIBANA_*_ENCRYPTIONKEY: must be 32+ chars. Generate with:
#   openssl rand -hex 32
# WARNING: if you already have an esdata volume with encrypted saved objects
# (alerting connectors, etc.), changing these after the fact breaks decryption
# of anything encrypted under the old key. Keep them stable once you have data
# you care about.

ELASTIC_PASSWORD=changeme
KIBANA_SYSTEM_PASSWORD=changeme
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=
KIBANA_SECURITY_ENCRYPTIONKEY=
KIBANA_REPORTING_ENCRYPTIONKEY=
